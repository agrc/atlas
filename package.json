    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@ugrc/eslint-config": "^1.3.0",
    "@ugrc/tsconfigs": "^1.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "baseline-browser-mapping": "^2.10.32",
