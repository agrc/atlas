    "@arcgis/map-components": "^5.0.19",
    "@esri/calcite-components": "^5.0.2",
    "@heroicons/react": "^2.2.0",
    "@react-types/shared": "^3.34.0",
    "@ugrc/esri-theme-toggle": "^2.0.0",
    "@ugrc/tailwind-preset": "^2.0.0",
    "@ugrc/utah-design-system": "^4.0.3",
    "@ugrc/utilities": "^5.0.0",
    "es-toolkit": "^1.46.1",
    "firebase": "^12.13.0",
    "ky": "^2.0.2",
    "lodash.startcase": "^4.4.0",
